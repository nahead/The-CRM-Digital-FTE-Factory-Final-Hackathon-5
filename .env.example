# Gemini AI API Key (FREE - Get from: https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Gmail API Credentials
GMAIL_CREDENTIALS_PATH=./credentials/gmail_credentials.json

# Twilio WhatsApp (FREE Sandbox - Get from: https://www.twilio.com/try-twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# PostgreSQL Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fte_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Application Settings
ENVIRONMENT=development
LOG_LEVEL=INFO
MAX_EMAIL_LENGTH=2000
MAX_WHATSAPP_LENGTH=1600
MAX_WEBFORM_LENGTH=1000
